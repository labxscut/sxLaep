# setuptools / pip build artifacts
*.egg-info/
.eggs/
dist/
build/
*.egg

# Dotfiles and dot-directories at any path depth (any subdir or repo root)
**/.*
**/.*/

!.github/
!.gitignore

# Python bytecode, caches, and tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage*
htmlcov/
.hypothesis/

# Virtual environments (local)
.venv/
venv/
env/

# Logs, scratch, and temp files
*.log
*.tmp
*.temp
*.bak
*.orig
.cache/
/tmp/
/temp/

# Jupyter
.ipynb_checkpoints/

# OS junk
.DS_Store
Thumbs.db
*~

# Editors (swap / recovery)
*.swp
*.swo
*.swn

# pip / build metadata sometimes left in tree
pip-wheel-metadata/
